# Server
PORT=3001
NODE_ENV=development

# Frontend (production CORS origin)
FRONTEND_URL=

# Redis (BullMQ + ioredis)
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Groq (LLM)
GROQ_API_KEY=

# Gemini (document understanding + Qdrant embeddings)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional overrides (defaults: gemini-embedding-001 @ 768 dimensions)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSIONS=768

# Enkrypt AI (output validation guardrails)
ENKRYPT_API_KEY=
ENKRYPT_BASE_URL=https://api.enkryptai.com
